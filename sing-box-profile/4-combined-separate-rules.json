{
  "log": {
    "level": "warn",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "type": "udp",
        "tag": "bootstrap",
        "server": "8.8.8.8"
      },
      {
        "type": "tls",
        "tag": "google",
        "server": "dns.google",
        "domain_resolver": "bootstrap"
      },
      {
        "type": "https",
        "tag": "geohide",
        "server": "dns.geohide.ru",
        "server_port": 444,
        "path": "/dns-query",
        "domain_resolver": "bootstrap"
      }
    ],
    "rules": [
      {
        "package_name": [
          "com.openai.chatgpt",
          "com.anthropic.claude",
          "com.microsoft.copilot",
          "com.deepl.mobiletranslator",
          "com.deepseek.chat",
          "com.duckduckgo.mobile.android",
          "org.mozilla.fennec_fdroid",
          "com.google.android.apps.bard",
          "com.google.android.googlequicksearchbox",
          "ai.x.grok",
          "ai.leonardo.leonardo",
          "ai.mistral.chat",
          "com.google.android.apps.labs.language.tailwind",
          "ai.qwenlm.chat.android",
          "com.suno.android",
          "org.telegram.messenger.beta"
        ],
        "server": "geohide"
      },
      {
        "rule_set": "geohide-domains",
        "server": "geohide"
      }
    ],
    "final": "google",
    "strategy": "prefer_ipv4",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "address": [
        "172.19.0.1/30"
      ],
      "auto_route": true,
      "strict_route": false,
      "stack": "gvisor"
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rule_set": [
      {
        "type": "remote",
        "tag": "geohide-domains",
        "format": "binary",
        "url": "https://github.com/Kira361323/Dns-rules/releases/latest/download/domains.srs",
        "update_interval": "24h"
      }
    ],
    "rules": [
      {
        "action": "sniff"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "default_domain_resolver": "bootstrap",
    "auto_detect_interface": true,
    "final": "direct"
  }
}
